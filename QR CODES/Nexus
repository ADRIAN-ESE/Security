<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>QR Nexus | Enterprise Code Management</title>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/crypto-js/4.1.1/crypto-js.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/3.9.1/chart.min.js"></script>
    <link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=DM+Mono:wght@400;500&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&display=swap" rel="stylesheet">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        :root {
            --bg-deep: #060912;
            --bg-base: #0c1121;
            --bg-card: rgba(255,255,255,0.03);
            --bg-card-hover: rgba(255,255,255,0.05);
            --border: rgba(255,255,255,0.07);
            --border-hover: rgba(255,255,255,0.15);
            --text-primary: #f0f4ff;
            --text-secondary: #7a8aaa;
            --text-muted: #3d4a63;
            --accent-blue: #3b7fff;
            --accent-purple: #8b5cf6;
            --accent-cyan: #06b6d4;
            --accent-emerald: #10b981;
            --accent-red: #ef4444;
            --accent-amber: #f59e0b;
            --glow-blue: rgba(59, 127, 255, 0.15);
            --glow-purple: rgba(139, 92, 246, 0.15);
            --radius-sm: 8px;
            --radius-md: 12px;
            --radius-lg: 16px;
            --radius-xl: 24px;
        }

        body {
            font-family: 'DM Sans', sans-serif;
            background: var(--bg-deep);
            color: var(--text-primary);
            height: 100vh;
            overflow: hidden;
            display: flex;
        }

        /* ─── Noise Texture Overlay ─── */
        body::before {
            content: '';
            position: fixed;
            inset: 0;
            background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
            pointer-events: none;
            z-index: 9999;
            opacity: 0.5;
        }

        /* ─── Sidebar ─── */
        .sidebar {
            width: 240px;
            min-width: 240px;
            height: 100vh;
            background: var(--bg-base);
            border-right: 1px solid var(--border);
            display: flex;
            flex-direction: column;
            position: relative;
            overflow: hidden;
        }

        .sidebar::before {
            content: '';
            position: absolute;
            top: -100px;
            left: -60px;
            width: 300px;
            height: 300px;
            background: radial-gradient(circle, rgba(59,127,255,0.08) 0%, transparent 70%);
            pointer-events: none;
        }

        .logo-area {
            padding: 24px 20px;
            border-bottom: 1px solid var(--border);
        }

        .logo-mark {
            width: 36px;
            height: 36px;
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            position: relative;
            box-shadow: 0 0 20px rgba(59,127,255,0.3);
        }

        .logo-mark svg { width: 18px; height: 18px; color: white; }

        .logo-text {
            font-family: 'Syne', sans-serif;
            font-weight: 800;
            font-size: 17px;
            letter-spacing: -0.3px;
            color: var(--text-primary);
            line-height: 1;
        }

        .logo-sub {
            font-size: 10px;
            color: var(--text-muted);
            font-family: 'DM Mono', monospace;
            letter-spacing: 0.5px;
            margin-top: 2px;
        }

        .nav-section {
            padding: 16px 12px;
            flex: 1;
            overflow-y: auto;
        }

        .nav-label {
            font-size: 9px;
            font-family: 'DM Mono', monospace;
            letter-spacing: 1.5px;
            color: var(--text-muted);
            text-transform: uppercase;
            padding: 0 8px;
            margin-bottom: 6px;
            margin-top: 16px;
        }

        .nav-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 9px 12px;
            border-radius: var(--radius-sm);
            cursor: pointer;
            transition: all 0.15s ease;
            border: 1px solid transparent;
            margin-bottom: 2px;
            background: none;
            width: 100%;
            text-align: left;
            font-family: 'DM Sans', sans-serif;
            font-size: 13.5px;
            font-weight: 500;
            color: var(--text-secondary);
        }

        .nav-item:hover {
            background: var(--bg-card);
            color: var(--text-primary);
            border-color: var(--border);
        }

        .nav-item.active {
            background: linear-gradient(135deg, rgba(59,127,255,0.12), rgba(139,92,246,0.08));
            color: var(--text-primary);
            border-color: rgba(59,127,255,0.25);
        }

        .nav-item svg { width: 15px; height: 15px; flex-shrink: 0; }

        .nav-badge {
            margin-left: auto;
            background: var(--accent-blue);
            color: white;
            font-size: 10px;
            font-weight: 600;
            padding: 2px 7px;
            border-radius: 20px;
            font-family: 'DM Mono', monospace;
        }

        .nav-badge.danger { background: var(--accent-red); }

        .user-area {
            padding: 16px 12px;
            border-top: 1px solid var(--border);
        }

        .user-card {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
        }

        .avatar {
            width: 32px;
            height: 32px;
            border-radius: 50%;
            background: linear-gradient(135deg, #10b981, #06b6d4);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            font-weight: 700;
            color: #0c1121;
            flex-shrink: 0;
        }

        .user-name {
            font-size: 13px;
            font-weight: 600;
            color: var(--text-primary);
            line-height: 1.2;
        }

        .user-role {
            font-size: 10px;
            color: var(--text-muted);
            font-family: 'DM Mono', monospace;
        }

        .online-dot {
            width: 7px;
            height: 7px;
            background: var(--accent-emerald);
            border-radius: 50%;
            margin-left: auto;
            box-shadow: 0 0 8px rgba(16,185,129,0.6);
            animation: pulse-dot 2s ease-in-out infinite;
        }

        @keyframes pulse-dot {
            0%, 100% { opacity: 1; box-shadow: 0 0 8px rgba(16,185,129,0.6); }
            50% { opacity: 0.7; box-shadow: 0 0 16px rgba(16,185,129,0.8); }
        }

        /* ─── Main Content ─── */
        .main {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            background: var(--bg-deep);
        }

        /* ─── Top Bar ─── */
        .topbar {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 16px 28px;
            border-bottom: 1px solid var(--border);
            background: rgba(6, 9, 18, 0.8);
            backdrop-filter: blur(20px);
            flex-shrink: 0;
        }

        .topbar-left { display: flex; align-items: center; gap: 12px; }

        .page-title {
            font-family: 'Syne', sans-serif;
            font-size: 20px;
            font-weight: 700;
            color: var(--text-primary);
            letter-spacing: -0.3px;
        }

        .status-pill {
            display: flex;
            align-items: center;
            gap: 5px;
            padding: 4px 10px;
            background: rgba(16,185,129,0.08);
            border: 1px solid rgba(16,185,129,0.2);
            border-radius: 20px;
            font-size: 11px;
            color: var(--accent-emerald);
            font-family: 'DM Mono', monospace;
        }

        .status-pill::before {
            content: '';
            width: 5px;
            height: 5px;
            background: var(--accent-emerald);
            border-radius: 50%;
            box-shadow: 0 0 6px rgba(16,185,129,0.8);
            animation: pulse-dot 2s ease-in-out infinite;
        }

        .topbar-right { display: flex; align-items: center; gap: 8px; }

        .icon-btn {
            width: 36px;
            height: 36px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            color: var(--text-secondary);
            transition: all 0.15s;
            position: relative;
        }

        .icon-btn:hover { color: var(--text-primary); border-color: var(--border-hover); background: var(--bg-card-hover); }
        .icon-btn svg { width: 16px; height: 16px; }

        .notif-dot {
            position: absolute;
            top: 6px;
            right: 6px;
            width: 6px;
            height: 6px;
            background: var(--accent-red);
            border-radius: 50%;
            border: 1.5px solid var(--bg-deep);
        }

        /* ─── Content Area ─── */
        .content {
            flex: 1;
            overflow-y: auto;
            padding: 24px 28px;
        }

        .content::-webkit-scrollbar { width: 5px; }
        .content::-webkit-scrollbar-track { background: transparent; }
        .content::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 3px; }

        /* ─── Views ─── */
        .view { display: none; }
        .view.active { display: block; }

        /* ─── Cards ─── */
        .card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 20px;
            transition: border-color 0.2s;
        }

        .card:hover { border-color: var(--border-hover); }

        .card-title {
            font-family: 'Syne', sans-serif;
            font-size: 15px;
            font-weight: 700;
            color: var(--text-primary);
            margin-bottom: 16px;
            display: flex;
            align-items: center;
            justify-content: space-between;
        }

        /* ─── Grid Layouts ─── */
        .grid-4 { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; }
        .grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 14px; }
        .grid-2 { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
        .grid-gen { display: grid; grid-template-columns: 420px 1fr; gap: 20px; }

        .space-y > * + * { margin-top: 14px; }

        /* ─── Stat Cards ─── */
        .stat-card {
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 20px;
            position: relative;
            overflow: hidden;
            transition: all 0.2s;
        }

        .stat-card::after {
            content: '';
            position: absolute;
            bottom: 0;
            left: 0;
            right: 0;
            height: 2px;
            background: var(--accent-color, linear-gradient(90deg, var(--accent-blue), var(--accent-purple)));
            opacity: 0.6;
        }

        .stat-card:hover { border-color: var(--border-hover); transform: translateY(-1px); }

        .stat-label { font-size: 11px; color: var(--text-muted); font-family: 'DM Mono', monospace; letter-spacing: 0.5px; text-transform: uppercase; margin-bottom: 8px; }
        .stat-value { font-family: 'Syne', sans-serif; font-size: 30px; font-weight: 800; line-height: 1; margin-bottom: 6px; }
        .stat-delta { font-size: 12px; display: flex; align-items: center; gap: 4px; }

        .stat-icon {
            position: absolute;
            top: 16px;
            right: 16px;
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .stat-icon svg { width: 17px; height: 17px; }

        /* ─── Buttons ─── */
        .btn {
            display: inline-flex;
            align-items: center;
            gap: 7px;
            padding: 9px 16px;
            border-radius: var(--radius-sm);
            font-size: 13px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.15s;
            border: 1px solid transparent;
            font-family: 'DM Sans', sans-serif;
        }

        .btn svg { width: 14px; height: 14px; }

        .btn-primary {
            background: linear-gradient(135deg, var(--accent-blue), var(--accent-purple));
            color: white;
            box-shadow: 0 4px 20px rgba(59,127,255,0.25);
        }

        .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 6px 25px rgba(59,127,255,0.4); }

        .btn-ghost {
            background: var(--bg-card);
            border-color: var(--border);
            color: var(--text-secondary);
        }

        .btn-ghost:hover { color: var(--text-primary); border-color: var(--border-hover); background: var(--bg-card-hover); }

        .btn-danger {
            background: rgba(239,68,68,0.1);
            border-color: rgba(239,68,68,0.3);
            color: var(--accent-red);
        }

        .btn-danger:hover { background: rgba(239,68,68,0.2); }

        .btn-success {
            background: rgba(16,185,129,0.1);
            border-color: rgba(16,185,129,0.3);
            color: var(--accent-emerald);
        }

        .btn-success:hover { background: rgba(16,185,129,0.2); }

        .btn-lg { padding: 13px 24px; font-size: 14px; border-radius: var(--radius-md); width: 100%; justify-content: center; }

        /* ─── Inputs ─── */
        .field-label { font-size: 11px; color: var(--text-secondary); font-weight: 600; margin-bottom: 6px; letter-spacing: 0.3px; text-transform: uppercase; font-family: 'DM Mono', monospace; }

        .input {
            width: 100%;
            background: rgba(0,0,0,0.25);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 10px 14px;
            color: var(--text-primary);
            font-size: 13.5px;
            font-family: 'DM Sans', sans-serif;
            outline: none;
            transition: all 0.15s;
        }

        .input:focus { border-color: var(--accent-blue); box-shadow: 0 0 0 3px rgba(59,127,255,0.1); }
        .input::placeholder { color: var(--text-muted); }

        select.input { cursor: pointer; }
        textarea.input { resize: none; }

        /* ─── Tab Row ─── */
        .tabs {
            display: flex;
            gap: 4px;
            background: rgba(0,0,0,0.25);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            padding: 4px;
            margin-bottom: 16px;
        }

        .tab {
            flex: 1;
            padding: 7px;
            border-radius: 5px;
            font-size: 12px;
            font-weight: 600;
            cursor: pointer;
            text-align: center;
            color: var(--text-muted);
            transition: all 0.15s;
            background: none;
            border: none;
            font-family: 'DM Sans', sans-serif;
        }

        .tab.active {
            background: linear-gradient(135deg, rgba(59,127,255,0.2), rgba(139,92,246,0.15));
            color: var(--text-primary);
            box-shadow: inset 0 1px 0 rgba(255,255,255,0.05);
        }

        .tab:not(.active):hover { color: var(--text-secondary); }

        /* ─── Toggle Switch ─── */
        .toggle-row {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 11px 14px;
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
        }

        .toggle-info { flex: 1; }
        .toggle-name { font-size: 13px; font-weight: 500; color: var(--text-primary); }
        .toggle-desc { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

        .toggle {
            width: 38px;
            height: 21px;
            background: var(--text-muted);
            border-radius: 20px;
            position: relative;
            cursor: pointer;
            transition: all 0.2s;
            flex-shrink: 0;
            border: none;
            outline: none;
        }

        .toggle::after {
            content: '';
            position: absolute;
            width: 15px;
            height: 15px;
            background: white;
            border-radius: 50%;
            top: 3px;
            left: 3px;
            transition: all 0.2s;
            box-shadow: 0 1px 4px rgba(0,0,0,0.4);
        }

        .toggle.on { background: var(--accent-blue); }
        .toggle.on::after { left: 20px; }

        /* ─── Badges ─── */
        .badge {
            display: inline-flex;
            align-items: center;
            gap: 4px;
            padding: 3px 9px;
            border-radius: 20px;
            font-size: 11px;
            font-weight: 600;
            font-family: 'DM Mono', monospace;
        }

        .badge::before { content: ''; width: 5px; height: 5px; border-radius: 50%; background: currentColor; }

        .badge-green { background: rgba(16,185,129,0.12); color: var(--accent-emerald); border: 1px solid rgba(16,185,129,0.25); }
        .badge-blue { background: rgba(59,127,255,0.12); color: var(--accent-blue); border: 1px solid rgba(59,127,255,0.25); }
        .badge-red { background: rgba(239,68,68,0.12); color: var(--accent-red); border: 1px solid rgba(239,68,68,0.25); }
        .badge-amber { background: rgba(245,158,11,0.12); color: var(--accent-amber); border: 1px solid rgba(245,158,11,0.25); }
        .badge-purple { background: rgba(139,92,246,0.12); color: var(--accent-purple); border: 1px solid rgba(139,92,246,0.25); }

        /* ─── Activity Feed ─── */
        .activity-item {
            display: flex;
            align-items: flex-start;
            gap: 12px;
            padding: 12px;
            border-radius: var(--radius-md);
            background: rgba(0,0,0,0.15);
            border: 1px solid var(--border);
            transition: border-color 0.15s;
        }

        .activity-item:hover { border-color: var(--border-hover); }
        .activity-item.alert { background: rgba(239,68,68,0.04); border-color: rgba(239,68,68,0.15); }

        .activity-icon {
            width: 36px;
            height: 36px;
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .activity-icon svg { width: 16px; height: 16px; }

        .activity-text { font-size: 13.5px; font-weight: 500; color: var(--text-primary); line-height: 1.3; }
        .activity-meta { font-size: 11.5px; color: var(--text-muted); margin-top: 2px; font-family: 'DM Mono', monospace; }
        .activity-time { font-size: 10.5px; color: var(--text-muted); white-space: nowrap; font-family: 'DM Mono', monospace; margin-left: auto; }

        /* ─── Quick Action Cards ─── */
        .quick-action {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
            cursor: pointer;
            transition: all 0.15s;
            background: var(--bg-card);
            width: 100%;
            text-align: left;
        }

        .quick-action:hover { border-color: var(--border-hover); transform: translateY(-1px); background: var(--bg-card-hover); }

        .qa-icon {
            width: 40px;
            height: 40px;
            border-radius: 10px;
            display: flex;
            align-items: center;
            justify-content: center;
            flex-shrink: 0;
        }

        .qa-icon svg { width: 18px; height: 18px; }
        .qa-title { font-size: 13.5px; font-weight: 600; color: var(--text-primary); }
        .qa-sub { font-size: 11px; color: var(--text-muted); margin-top: 1px; }

        /* ─── Table ─── */
        .table-wrap { overflow-x: auto; }

        table { width: 100%; border-collapse: collapse; }

        thead th {
            padding: 10px 14px;
            text-align: left;
            font-size: 10.5px;
            font-family: 'DM Mono', monospace;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            border-bottom: 1px solid var(--border);
            font-weight: 500;
        }

        tbody td {
            padding: 14px;
            font-size: 13px;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            color: var(--text-secondary);
        }

        tbody tr:hover td { background: var(--bg-card); }
        tbody tr.threat-row td { background: rgba(239,68,68,0.03); }
        tbody tr.threat-row:hover td { background: rgba(239,68,68,0.06); }

        .code-id { font-family: 'DM Mono', monospace; color: var(--text-primary); font-size: 12px; }

        .content-cell {
            max-width: 200px;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
            font-family: 'DM Mono', monospace;
            font-size: 11.5px;
        }

        .action-btns { display: flex; gap: 8px; justify-content: flex-end; align-items: center; }

        .tbl-btn {
            font-size: 12px;
            padding: 4px 10px;
            border-radius: 5px;
            cursor: pointer;
            transition: all 0.15s;
            border: 1px solid var(--border);
            background: var(--bg-card);
            color: var(--text-secondary);
            font-family: 'DM Sans', sans-serif;
            font-weight: 500;
        }

        .tbl-btn:hover { color: var(--text-primary); border-color: var(--border-hover); }
        .tbl-btn.red { color: var(--accent-red); border-color: rgba(239,68,68,0.2); background: rgba(239,68,68,0.06); }
        .tbl-btn.red:hover { background: rgba(239,68,68,0.15); }
        .tbl-btn.amber { color: var(--accent-amber); border-color: rgba(245,158,11,0.2); background: rgba(245,158,11,0.06); }

        /* ─── Search Row ─── */
        .search-wrap { position: relative; }
        .search-wrap svg { position: absolute; left: 11px; top: 50%; transform: translateY(-50%); width: 14px; height: 14px; color: var(--text-muted); pointer-events: none; }
        .search-wrap .input { padding-left: 34px; }

        /* ─── Generator Preview ─── */
        .preview-box {
            background: rgba(0,0,0,0.3);
            border-radius: var(--radius-lg);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 340px;
            position: relative;
            overflow: hidden;
            border: 1px solid var(--border);
        }

        .preview-placeholder {
            text-align: center;
            color: var(--text-muted);
        }

        .preview-placeholder svg { width: 56px; height: 56px; opacity: 0.3; margin: 0 auto 12px; display: block; }
        .preview-placeholder p { font-size: 13px; }

        #gen-qr-wrapper {
            background: white;
            padding: 20px;
            border-radius: var(--radius-md);
            display: none;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

        /* Scan animation */
        .scan-anim {
            position: absolute;
            inset: 0;
            pointer-events: none;
        }

        .scan-line-el {
            position: absolute;
            left: 10%;
            right: 10%;
            height: 1px;
            background: linear-gradient(90deg, transparent, rgba(6,182,212,0.8), transparent);
            top: 10%;
            animation: scanMove 2s ease-in-out infinite;
            opacity: 0;
            display: none;
        }

        @keyframes scanMove {
            0% { top: 10%; opacity: 0; }
            10% { opacity: 1; }
            90% { opacity: 1; }
            100% { top: 90%; opacity: 0; }
        }

        .scanning .scan-line-el { display: block; }

        /* ─── Metadata Grid ─── */
        .meta-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            padding: 14px;
            background: rgba(0,0,0,0.2);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            margin-top: 14px;
        }

        .meta-label { font-size: 10px; font-family: 'DM Mono', monospace; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 3px; }
        .meta-value { font-size: 12px; font-family: 'DM Mono', monospace; color: var(--text-secondary); }
        .meta-value.hi { color: var(--accent-emerald); }
        .meta-value.blue { color: var(--accent-blue); }

        /* ─── Download Row ─── */
        .dl-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 8px; margin-top: 12px; }

        .dl-btn {
            padding: 10px;
            background: var(--bg-card);
            border: 1px solid var(--border);
            border-radius: var(--radius-sm);
            text-align: center;
            font-size: 12px;
            font-weight: 600;
            color: var(--text-secondary);
            cursor: pointer;
            transition: all 0.15s;
            font-family: 'DM Mono', monospace;
        }

        .dl-btn:hover { color: var(--text-primary); border-color: var(--border-hover); background: var(--bg-card-hover); }
        .dl-btn.primary { background: linear-gradient(135deg, rgba(59,127,255,0.15), rgba(139,92,246,0.1)); border-color: rgba(59,127,255,0.3); color: var(--accent-blue); }

        /* ─── Security ─── */
        .threat-card {
            padding: 14px;
            border-radius: var(--radius-md);
            display: flex;
            gap: 12px;
            align-items: flex-start;
        }

        .threat-card.critical { background: rgba(239,68,68,0.06); border: 1px solid rgba(239,68,68,0.2); }
        .threat-card.warning { background: rgba(245,158,11,0.06); border: 1px solid rgba(245,158,11,0.2); }

        .threat-icon { width: 36px; height: 36px; border-radius: 8px; display: flex; align-items: center; justify-content: center; flex-shrink: 0; }
        .threat-icon svg { width: 16px; height: 16px; }

        .threat-title { font-size: 13px; font-weight: 600; margin-bottom: 4px; }
        .threat-desc { font-size: 12px; color: var(--text-muted); line-height: 1.5; }
        .threat-actions { display: flex; gap: 8px; margin-top: 10px; }
        .threat-time { font-size: 10.5px; color: var(--text-muted); font-family: 'DM Mono', monospace; margin-left: auto; flex-shrink: 0; }

        /* ─── Score Bar ─── */
        .score-bar-wrap { margin-bottom: 6px; }
        .score-bar-top { display: flex; justify-content: space-between; font-size: 12px; margin-bottom: 4px; }
        .score-bar-track { height: 6px; background: rgba(255,255,255,0.06); border-radius: 4px; overflow: hidden; }
        .score-bar-fill { height: 100%; border-radius: 4px; transition: width 1s ease; }

        /* ─── Compliance Card ─── */
        .compliance-item {
            display: flex;
            align-items: center;
            justify-content: space-between;
            padding: 12px 14px;
            border-radius: var(--radius-sm);
            border: 1px solid var(--border);
            background: rgba(0,0,0,0.15);
        }

        .compliance-item.pass { border-color: rgba(16,185,129,0.2); background: rgba(16,185,129,0.04); }
        .compliance-item.pending { border-color: rgba(245,158,11,0.2); background: rgba(245,158,11,0.04); }

        .compliance-name { font-size: 13px; font-weight: 600; color: var(--text-primary); }
        .compliance-status { font-size: 11px; font-family: 'DM Mono', monospace; }
        .compliance-status.pass { color: var(--accent-emerald); }
        .compliance-status.pending { color: var(--accent-amber); }

        .check-icon { width: 20px; height: 20px; border-radius: 50%; display: flex; align-items: center; justify-content: center; }
        .check-icon.pass { background: rgba(16,185,129,0.15); color: var(--accent-emerald); }
        .check-icon.pending { background: rgba(245,158,11,0.15); color: var(--accent-amber); }
        .check-icon svg { width: 11px; height: 11px; }

        /* ─── Analytics ─── */
        .geo-bar { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: var(--radius-sm); background: rgba(0,0,0,0.15); border: 1px solid var(--border); }
        .geo-flag { font-size: 20px; width: 28px; text-align: center; }
        .geo-country { font-size: 13px; color: var(--text-secondary); flex: 1; }
        .geo-track { width: 120px; height: 5px; background: rgba(255,255,255,0.06); border-radius: 3px; overflow: hidden; }
        .geo-fill { height: 100%; background: linear-gradient(90deg, var(--accent-blue), var(--accent-purple)); border-radius: 3px; }
        .geo-pct { font-size: 12px; font-family: 'DM Mono', monospace; color: var(--text-primary); width: 36px; text-align: right; }

        .device-row { display: flex; align-items: center; gap: 12px; padding: 10px 12px; border-radius: var(--radius-sm); background: rgba(0,0,0,0.15); border: 1px solid var(--border); }
        .device-name { font-size: 13px; color: var(--text-secondary); flex: 1; }
        .device-count { font-size: 12px; font-family: 'DM Mono', monospace; color: var(--text-primary); }

        /* ─── Team ─── */
        .member-card {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 14px 16px;
            background: rgba(0,0,0,0.15);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            transition: all 0.15s;
        }

        .member-card:hover { border-color: var(--border-hover); }

        .member-avatar {
            width: 40px;
            height: 40px;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 13px;
            font-weight: 700;
            flex-shrink: 0;
        }

        .member-name { font-size: 13.5px; font-weight: 600; color: var(--text-primary); }
        .member-email { font-size: 11px; color: var(--text-muted); font-family: 'DM Mono', monospace; margin-top: 1px; }
        .member-role { font-size: 11px; }
        .member-actions { margin-left: auto; display: flex; gap: 6px; }

        /* ─── Permission Table ─── */
        .perm-grid {
            display: grid;
            grid-template-columns: 1fr repeat(4, 80px);
            gap: 0;
        }

        .perm-header {
            padding: 8px 12px;
            font-size: 10px;
            font-family: 'DM Mono', monospace;
            color: var(--text-muted);
            text-transform: uppercase;
            letter-spacing: 0.5px;
            text-align: center;
            border-bottom: 1px solid var(--border);
        }

        .perm-header:first-child { text-align: left; }

        .perm-row {
            display: contents;
        }

        .perm-row > div {
            padding: 10px 12px;
            font-size: 12.5px;
            border-bottom: 1px solid rgba(255,255,255,0.03);
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .perm-row > div:first-child { justify-content: flex-start; color: var(--text-primary); font-weight: 500; }

        .perm-check { color: var(--accent-emerald); }
        .perm-x { color: var(--text-muted); }

        /* ─── Invite Box ─── */
        .invite-row { display: flex; gap: 10px; }
        .invite-row .input { flex: 1; }

        /* ─── Notification Toast ─── */
        #toast {
            position: fixed;
            bottom: 24px;
            right: 24px;
            z-index: 10000;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .toast-item {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px 16px;
            background: var(--bg-base);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
            font-size: 13px;
            color: var(--text-primary);
            box-shadow: 0 10px 40px rgba(0,0,0,0.5);
            animation: toastIn 0.3s ease;
            max-width: 320px;
        }

        .toast-item svg { width: 16px; height: 16px; flex-shrink: 0; }
        .toast-item.success { border-color: rgba(16,185,129,0.3); }
        .toast-item.success svg { color: var(--accent-emerald); }
        .toast-item.error { border-color: rgba(239,68,68,0.3); }
        .toast-item.error svg { color: var(--accent-red); }
        .toast-item.info { border-color: rgba(59,127,255,0.3); }
        .toast-item.info svg { color: var(--accent-blue); }

        @keyframes toastIn {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        /* ─── Audit Results ─── */
        .audit-result {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 10px 14px;
            border-radius: var(--radius-sm);
            font-size: 12.5px;
            background: rgba(0,0,0,0.15);
            border: 1px solid var(--border);
        }

        .audit-result svg { width: 14px; height: 14px; flex-shrink: 0; }
        .audit-result.pass svg { color: var(--accent-emerald); }
        .audit-result.fail svg { color: var(--accent-red); }
        .audit-result.warn svg { color: var(--accent-amber); }

        /* ─── Helpers ─── */
        .flex { display: flex; }
        .flex-col { flex-direction: column; }
        .items-center { align-items: center; }
        .items-start { align-items: flex-start; }
        .justify-between { justify-content: space-between; }
        .gap-2 { gap: 8px; }
        .gap-3 { gap: 12px; }
        .gap-4 { gap: 16px; }
        .mt-2 { margin-top: 8px; }
        .mt-3 { margin-top: 12px; }
        .mt-4 { margin-top: 16px; }
        .mb-1 { margin-bottom: 4px; }
        .mb-3 { margin-bottom: 12px; }
        .text-sm { font-size: 13px; }
        .text-xs { font-size: 11px; font-family: 'DM Mono', monospace; }
        .text-muted { color: var(--text-muted); }
        .text-secondary { color: var(--text-secondary); }
        .text-emerald { color: var(--accent-emerald); }
        .text-blue { color: var(--accent-blue); }
        .text-red { color: var(--accent-red); }
        .text-amber { color: var(--accent-amber); }
        .font-semibold { font-weight: 600; }
        .w-full { width: 100%; }
        .hidden { display: none !important; }
        .section-header { display: flex; align-items: center; justify-content: space-between; margin-bottom: 16px; }
        .section-title { font-family: 'Syne', sans-serif; font-size: 15px; font-weight: 700; color: var(--text-primary); }
        .hint { font-size: 11.5px; color: var(--text-muted); display: flex; align-items: center; gap: 5px; margin-top: 5px; }
        .hint svg { width: 12px; height: 12px; }
        .divider { height: 1px; background: var(--border); margin: 16px 0; }
        .col-span-2 { grid-column: span 2; }
    </style>
</head>
