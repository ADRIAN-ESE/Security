<!-- Toast Container -->
<div id="toast"></div>

<script>
// ─── Navigation ───────────────────────────────────────────
const pageNames = { dashboard: 'Dashboard', generator: 'Create QR Code', management: 'Code Management', security: 'Security Center', analytics: 'Analytics', team: 'Team & Access' };

function switchView(name, btnEl) {
    document.querySelectorAll('.view').forEach(v => v.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(b => b.classList.remove('active'));
    document.getElementById('view-' + name).classList.add('active');
    document.getElementById('page-title').textContent = pageNames[name];
    if (btnEl) btnEl.classList.add('active');

    if (name === 'analytics') initCharts();
}

// ─── Content Types ────────────────────────────────────────
let currentType = 'url';

function setContentType(type, btn) {
    currentType = type;
    document.querySelectorAll('.tab').forEach(t => t.classList.remove('active'));
    if (btn) btn.classList.add('active');
    ['url','vcard','wifi','email'].forEach(t => {
        document.getElementById('input-' + t).classList.toggle('hidden', t !== type);
    });
    livePreview();
}

function getContent() {
    switch(currentType) {
        case 'url': return document.getElementById('gen-url').value || null;
        case 'vcard': {
            const n = document.getElementById('vc-name').value;
            if (!n) return null;
            const p = document.getElementById('vc-phone').value;
            const e = document.getElementById('vc-email').value;
            const c = document.getElementById('vc-company').value;
            return `BEGIN:VCARD\nVERSION:3.0\nFN:${n}\nTEL:${p}\nEMAIL:${e}\nORG:${c}\nEND:VCARD`;
        }
        case 'wifi': {
            const s = document.getElementById('wf-ssid').value;
            if (!s) return null;
            const p = document.getElementById('wf-pass').value;
            const t = document.getElementById('wf-enc').value;
            return `WIFI:T:${t};S:${s};P:${p};;`;
        }
        case 'email': {
            const to = document.getElementById('em-to').value;
            if (!to) return null;
            const sub = document.getElementById('em-sub').value;
            const body = document.getElementById('em-body').value;
            return `mailto:${to}?subject=${encodeURIComponent(sub)}&body=${encodeURIComponent(body)}`;
        }
    }
    return null;
}

// ─── Color Sync ───────────────────────────────────────────
document.getElementById('gen-fg').addEventListener('input', e => {
    document.getElementById('fg-hex').textContent = e.target.value.toUpperCase();
    livePreview();
});
document.getElementById('gen-bg').addEventListener('input', e => {
    document.getElementById('bg-hex').textContent = e.target.value.toUpperCase();
    livePreview();
});

// ─── QR Generation ────────────────────────────────────────
let qrInstance = null;
let debounceTimer = null;

function livePreview() {
    clearTimeout(debounceTimer);
    debounceTimer = setTimeout(() => {
        const content = getContent();
        if (content) generateQR(true);
    }, 400);
}

function generateQR(silent = false) {
    const content = getContent();
    if (!content) {
        if (!silent) showToast('Please enter content first', 'error');
        return;
    }

    const fg = document.getElementById('gen-fg').value;
    const bg = document.getElementById('gen-bg').value;
    const size = parseInt(document.getElementById('gen-size').value);
    const errLevel = document.getElementById('gen-error').value;

    const errMap = { L: QRCode.CorrectLevel.L, M: QRCode.CorrectLevel.M, H: QRCode.CorrectLevel.H };

    const container = document.getElementById('gen-qrcode');
    container.innerHTML = '';
    document.getElementById('gen-placeholder').classList.add('hidden');
    document.getElementById('gen-qr-wrapper').style.display = 'block';

    try {
        qrInstance = new QRCode(container, {
            text: content,
            width: Math.min(size, 300),
            height: Math.min(size, 300),
            colorDark: fg,
            colorLight: bg,
            correctLevel: errMap[errLevel] || QRCode.CorrectLevel.H
        });
    } catch(e) {
        showToast('QR generation failed: ' + e.message, 'error');
        return;
    }

    // Show metadata
    const hash = CryptoJS.SHA256(content).toString();
    document.getElementById('gen-hash').textContent = hash.substring(0, 32) + '…';
    document.getElementById('gen-time').textContent = new Date().toLocaleTimeString();
    document.getElementById('gen-metadata').classList.remove('hidden');
    document.getElementById('gen-download').classList.remove('hidden');

    if (!silent) showToast('QR code generated successfully', 'success');
}

// ─── Test Scan ────────────────────────────────────────────
function testScan() {
    const content = getContent();
    if (!content) { showToast('Generate a QR code first', 'error'); return; }

    const box = document.getElementById('preview-container');
    box.classList.add('scanning');
    setTimeout(() => {
        box.classList.remove('scanning');
        showToast('✓ Scan verified · Content: ' + content.substring(0,40) + (content.length > 40 ? '…' : ''), 'success');
    }, 2000);
}

// ─── Simulate Threat ─────────────────────────────────────
function simulateThreat() {
    showToast('⚠ Attack simulation: Quishing attempt blocked', 'error');
    setTimeout(() => showToast('All users protected · Threat logged', 'info'), 1200);
}

// ─── Download ─────────────────────────────────────────────
function downloadCode(format) {
    const content = getContent();
    if (!content) { showToast('Generate a QR code first', 'error'); return; }
    if (format === 'png') {
        const canvas = document.querySelector('#gen-qrcode canvas');
        if (canvas) {
            const a = document.createElement('a');
            a.download = 'qr-nexus-code.png';
            a.href = canvas.toDataURL();
            a.click();
            showToast('PNG downloaded', 'success');
        }
    } else {
        showToast(`${format.toUpperCase()} export queued — download will begin shortly`, 'info');
    }
}

// ─── Security Audit ──────────────────────────────────────
function runSecurityAudit() {
    showToast('Running full security audit…', 'info');
    setTimeout(() => {
        const checks = [
            { label: 'URL scheme validation', status: 'pass' },
            { label: 'Domain allowlist check', status: 'pass' },
            { label: 'Redirect chain analysis', status: 'pass' },
            { label: 'Quishing pattern scan', status: 'pass' },
            { label: 'Certificate verification', status: 'pass' },
            { label: 'Entropy analysis on slugs', status: 'warn', note: '3 low-entropy URLs' },
            { label: 'Threat feed lookup', status: 'pass' },
            { label: 'GDPR compliance check', status: 'pass' },
            { label: 'Suspicious domain #8831', status: 'fail', note: 'Credential harvesting detected' },
        ];

        const auditBox = document.getElementById('audit-results');
        const list = document.getElementById('audit-list');
        list.innerHTML = '';
        checks.forEach(c => {
            const icons = {
                pass: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>`,
                fail: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>`,
                warn: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01M12 2a10 10 0 110 20A10 10 0 0112 2z"/></svg>`
            };
            const el = document.createElement('div');
            el.className = `audit-result ${c.status}`;
            el.innerHTML = icons[c.status] + `<span style="flex:1;color:var(--text-secondary)">${c.label}</span>${c.note ? `<span class="text-xs text-muted">${c.note}</span>` : ''}`;
            list.appendChild(el);
        });
        auditBox.classList.remove('hidden');
        showToast('Audit complete — 1 critical, 1 warning found', 'success');

        // Switch to security view
        switchView('security', document.querySelectorAll('.nav-item')[3]);
    }, 2500);
}

// ─── Charts ───────────────────────────────────────────────
let chartsInitialized = false;

function initCharts() {
    if (chartsInitialized) return;
    chartsInitialized = true;

    const chartDefaults = {
        color: '#7a8aaa',
        plugins: { legend: { display: false } },
        scales: {
            x: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#3d4a63', font: { size: 11 } } },
            y: { grid: { color: 'rgba(255,255,255,0.04)' }, ticks: { color: '#3d4a63', font: { size: 11 } } }
        }
    };

    // Scan line chart
    const days = Array.from({length: 30}, (_, i) => {
        const d = new Date();
        d.setDate(d.getDate() - (29 - i));
        return d.toLocaleDateString('en-US', {month:'short', day:'numeric'});
    });
    const scans = Array.from({length: 30}, () => Math.floor(Math.random() * 2000 + 500));

    new Chart(document.getElementById('scanChart'), {
        type: 'line',
        data: {
            labels: days.filter((_, i) => i % 5 === 0),
            datasets: [{
                data: scans.filter((_, i) => i % 5 === 0),
                borderColor: '#3b7fff',
                backgroundColor: 'rgba(59,127,255,0.08)',
                borderWidth: 2,
                pointRadius: 3,
                pointBackgroundColor: '#3b7fff',
                fill: true,
                tension: 0.4
            }]
        },
        options: { ...chartDefaults, maintainAspectRatio: true }
    });

    // Device doughnut chart
    new Chart(document.getElementById('deviceChart'), {
        type: 'doughnut',
        data: {
            labels: ['iOS', 'Android', 'Desktop', 'Other'],
            datasets: [{
                data: [42, 38, 14, 6],
                backgroundColor: ['#3b7fff', '#8b5cf6', '#06b6d4', '#3d4a63'],
                borderColor: '#060912',
                borderWidth: 3
            }]
        },
        options: {
            maintainAspectRatio: true,
            plugins: {
                legend: {
                    display: true,
                    position: 'bottom',
                    labels: { color: '#7a8aaa', font: { size: 11 }, padding: 14, boxWidth: 12, boxHeight: 12 }
                }
            }
        }
    });
}

// ─── Toast ────────────────────────────────────────────────
function showToast(msg, type = 'info') {
    const icons = {
        success: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        error: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
        info: `<svg fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`
    };
    const toast = document.getElementById('toast');
    const el = document.createElement('div');
    el.className = `toast-item ${type}`;
    el.innerHTML = icons[type] + `<span>${msg}</span>`;
    toast.appendChild(el);
    setTimeout(() => { el.style.opacity = '0'; el.style.transform = 'translateX(20px)'; el.style.transition = 'all 0.3s'; setTimeout(() => el.remove(), 300); }, 3500);
}
</script>
